{
  "name": "@auth/backend",
  "version": "0.3.0",
  "description": "OpenAuthFederated Backend SDK — a Federated-compatible drop-in: createFederatedClient, federatedClient (users/sessions/organizations), authenticateRequest, verifyToken, federatedMiddleware/requireAuth/getAuth, and the embedded createFederatedFrontend.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:saml": "node test/saml-roundtrip.cjs",
    "test:creds": "node test/credentials.cjs",
    "test": "node test/credentials.cjs && node test/saml-roundtrip.cjs"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.9.0",
    "xml-crypto": "^6.1.2"
  }
}
